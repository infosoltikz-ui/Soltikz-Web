generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
  ENTERPRISE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ResumeStatus {
  DRAFT
  IN_PROGRESS
  READY
  ARCHIVED
}

enum ResumeVisibility {
  PRIVATE
  PUBLIC
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  avatar        String?
  phone         String?
  country       String?
  timezone      String?
  role          Role      @default(USER)
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean   @default(false)
  lastLogin     DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  sessions          Session[]
  refreshTokens     RefreshToken[]
  emailVerifications EmailVerification[]
  passwordResets    PasswordReset[]
  profile           UserProfile?
  notifications     Notification[]
  activityLogs      ActivityLog[]
  settings          Settings?
  subscriptions     Subscription[]
  resumes           Resume[]
  payments          Payment[]
  exports           ExportHistory[]
  shares            ResumeShare[]
  exportAnalytics   ExportAnalytics[]
  coverLetters      CoverLetter[]
  coverLetterHistories CoverLetterHistory[]
  coverLetterAnalytics CoverLetterAnalytics[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model UserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio       String?
  headline  String?
  website   String?
  github    String?
  linkedin  String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}

model Settings {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme              String   @default("light")
  emailNotifications Boolean  @default(true)
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ---------------------------------------------------------
// Placeholders for Future Modules
// ---------------------------------------------------------

model Subscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId    String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResumeTemplate {
  id           String   @id @default(uuid())
  name         String
  thumbnail    String?
  previewImage String?
  category     String?
  isPremium    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  resumes      Resume[]
}

model Resume {
  id                   String           @id @default(uuid())
  userId               String
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                String
  slug                 String           @unique
  templateId           String?
  template             ResumeTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  status               ResumeStatus     @default(DRAFT)
  visibility           ResumeVisibility @default(PRIVATE)
  completionPercentage Int              @default(0)
  isFavorite           Boolean          @default(false)
  isArchived           Boolean          @default(false)
  content              Json?

  // Presentation Settings (Sprint 3.5)
  selectedTemplate     String?          @default("modern")
  defaultTheme         String?          @default("blue")
  primaryColor         String?
  fontFamily           String?          @default("inter")
  fontSize             String?          @default("medium")
  lineSpacing          String?          @default("normal")
  sectionSpacing       String?          @default("comfortable")
  pageMargin           String?          @default("medium")
  showProfilePhoto     Boolean          @default(true)
  showIcons            Boolean          @default(true)
  showSectionDividers  Boolean          @default(true)
  
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?

  versions             ResumeVersion[]
  atsReports           ATSReport[]
  exports              ExportHistory[]
  shares               ResumeShare[]
  exportAnalytics      ExportAnalytics[]
  coverLetters         CoverLetter[]
  
  personal             ResumePersonal?
  summary              ResumeSummary?
  
  experiences          ResumeExperience[]
  educations           ResumeEducation[]
  skills               ResumeSkill[]
  projects             ResumeProject[]
  certifications       ResumeCertification[]
  languages            ResumeLanguage[]
  achievements         ResumeAchievement[]
  awards               ResumeAward[]
  interests            ResumeInterest[]
  references           ResumeReference[]
}

model ResumeVersion {
  id        String   @id @default(uuid())
  resumeId  String
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  content   Json
  createdAt DateTime @default(now())
}

model ATSReport {
  id        String   @id @default(uuid())
  resumeId  String
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  score     Int
  feedback  Json
  createdAt DateTime @default(now())
}


model Payment {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Float
  currency      String
  status        String
  transactionId String   @unique
  createdAt     DateTime @default(now())
}

model ResumePersonal {
  id           String   @id @default(uuid())
  resumeId     String   @unique
  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  
  firstName    String?
  lastName     String?
  title        String?
  email        String?
  phone        String?
  countryCode  String?
  location     String?
  city         String?
  state        String?
  country      String?
  linkedin     String?
  github       String?
  portfolio    String?
  website      String?
  profileImage String?
  about        String?  @db.Text
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ResumeSummary {
  id           String   @id @default(uuid())
  resumeId     String   @unique
  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  content      String?  @db.Text
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ResumeExperience {
  id               String   @id @default(uuid())
  resumeId         String
  resume           Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  companyName      String
  jobTitle         String
  employmentType   String?
  city             String?
  state            String?
  country          String?
  startDate        String?
  endDate          String?
  currentlyWorking Boolean  @default(false)
  description      String?  @db.Text
  displayOrder     Int      @default(0)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ResumeEducation {
  id                String   @id @default(uuid())
  resumeId          String
  resume            Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  institution       String
  degree            String?
  fieldOfStudy      String?
  grade             String?
  city              String?
  country           String?
  startDate         String?
  endDate           String?
  currentlyStudying Boolean  @default(false)
  description       String?  @db.Text
  displayOrder      Int      @default(0)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ResumeSkill {
  id           String   @id @default(uuid())
  resumeId     String
  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  name         String
  category     String?
  proficiency  String?
  displayOrder Int      @default(0)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ResumeProject {
  id           String   @id @default(uuid())
  resumeId     String
  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  title        String
  description  String?  @db.Text
  technologies String[]
  githubUrl    String?
  liveUrl      String?
  startDate    String?
  endDate      String?
  featured     Boolean  @default(false)
  displayOrder Int      @default(0)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ResumeCertification {
  id                   String   @id @default(uuid())
  resumeId             String
  resume               Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  certificationName    String
  issuingOrganization  String?
  credentialId         String?
  credentialUrl        String?
  issueDate            String?
  expirationDate       String?
  neverExpires         Boolean  @default(false)
  displayOrder         Int      @default(0)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ResumeLanguage {
  id           String   @id @default(uuid())
  resumeId     String
  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  language     String
  proficiency  String   @default("Intermediate")
  displayOrder Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ResumeAchievement {
  id              String   @id @default(uuid())
  resumeId        String
  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  title           String
  description     String?  @db.Text
  achievementDate String?
  displayOrder    Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ResumeAward {
  id           String   @id @default(uuid())
  resumeId     String
  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  awardName    String
  issuer       String?
  awardDate    String?
  description  String?  @db.Text
  displayOrder Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ResumeInterest {
  id           String   @id @default(uuid())
  resumeId     String
  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  interest     String
  category     String?
  displayOrder Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ResumeReference {
  id                   String   @id @default(uuid())
  resumeId             String
  resume               Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  name                 String
  designation          String?
  company              String?
  email                String?
  phone                String?
  relationship         String?
  availableUponRequest Boolean  @default(false)
  displayOrder         Int      @default(0)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ==========================================
// SPRINT 4.1A - AI FOUNDATION MODELS
// ==========================================

enum AIProvider {
  OPENAI
  CLAUDE
  GEMINI
}

enum AIRole {
  SYSTEM
  USER
  ASSISTANT
}

model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  resumeId  String?
  provider  AIProvider
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  messages  AIMessage[]
  usage     AIUsage[]
}

model AIMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           AIRole
  content        String   @db.Text
  tokens         Int?
  createdAt      DateTime @default(now())
  
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AIUsage {
  id               String   @id @default(cuid())
  conversationId   String
  provider         AIProvider
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCost    Decimal
  latency          Int
  createdAt        DateTime @default(now())
  
  conversation     AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AISettings {
  id             String   @id @default(cuid())
  userId         String   @unique
  provider       AIProvider
  preferredModel String
  temperature    Float    @default(0.7)
  maxTokens      Int      @default(1000)
  stream         Boolean  @default(true)
  language       String   @default("English")
  tone           String   @default("Professional")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ==========================================
// SPRINT 4.1C - AI PLATFORM SERVICES
// ==========================================

model AIPrompt {
  id           String     @id @default(cuid())
  category     String
  version      Int
  provider     AIProvider? // Null means compatible with all
  systemPrompt String     @db.Text
  userPrompt   String     @db.Text
  variables    String[]
  description  String?    @db.Text
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([category, version])
}

model AICache {
  id        String     @id @default(cuid())
  hashKey   String     @unique
  provider  AIProvider
  model     String
  response  String     @db.Text
  tokens    Int
  expiresAt DateTime
  createdAt DateTime   @default(now())

  @@index([hashKey])
}

model AIAuditLog {
  id             String     @id @default(cuid())
  userId         String
  conversationId String?
  promptId       String?
  provider       AIProvider
  model          String
  tokens         Int
  latency        Int
  cost           Decimal
  status         String     // "SUCCESS" | "FAILED"
  errorMessage   String?    @db.Text
  createdAt      DateTime   @default(now())

  @@index([userId])
  @@index([status])
}

model AIRateLimit {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "MINUTE" | "HOUR" | "DAY"
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
}

// ==========================================
// SPRINT 7 - EXPORT ENGINE
// ==========================================

model ExportHistory {
  id          String   @id @default(uuid())
  resumeId    String
  userId      String
  format      String   // "PDF" | "DOCX" | "HTML" | "JSON"
  template    String?  // e.g., "modern", "classic"
  fileSize    Int?     // size in bytes
  durationMs  Int?     // time taken to generate
  status      String   // "SUCCESS" | "FAILED"
  error       String?  @db.Text
  createdAt   DateTime @default(now())

  resume      Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resumeId])
}

model ResumeShare {
  id          String   @id @default(uuid())
  resumeId    String
  userId      String
  token       String   @unique
  url         String
  type        String   // "PUBLIC" | "PRIVATE" | "PASSWORD"
  passwordHash String?
  views       Int      @default(0)
  downloads   Int      @default(0)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  resume      Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resumeId])
}

model ExportAnalytics {
  id          String   @id @default(uuid())
  resumeId    String
  userId      String
  action      String   // "DOWNLOAD_PDF", "SHARE_LINK_CREATED", etc.
  metadata    Json?
  createdAt   DateTime @default(now())

  resume      Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
}

// ==========================================
// SPRINT 8 - COVER LETTER GENERATOR
// ==========================================

model CoverLetter {
  id              String   @id @default(uuid())
  userId          String
  resumeId        String
  title           String?
  companyName     String?
  position        String?
  jobDescription  String?  @db.Text
  content         String?  @db.Text
  template        String   @default("professional")
  tone            String   @default("professional")
  length          String   @default("medium")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  histories       CoverLetterHistory[]
}

model CoverLetterHistory {
  id              String   @id @default(uuid())
  coverLetterId   String
  userId          String
  action          String   // "GENERATED", "UPDATED", "EXPORTED_PDF"
  createdAt       DateTime @default(now())

  coverLetter     CoverLetter @relation(fields: [coverLetterId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([coverLetterId])
}

model CoverLetterAnalytics {
  id              String   @id @default(uuid())
  userId          String
  action          String   // "GENERATION", "EXPORT", "REWRITE"
  tokens          Int?
  cost            Decimal?
  template        String?
  metadata        Json?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
}

