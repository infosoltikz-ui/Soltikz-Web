{
  "buildCommand": "npm run build && npx tsc --project server/tsconfig.json",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "server/dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

