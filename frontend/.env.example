# =============================================================
#  FRONTEND ENVIRONMENT VARIABLES - Copy to Vercel env settings
#  NOTE: All VITE_ variables MUST NOT be marked as "Sensitive"
#        in Vercel because they are embedded at BUILD TIME.
# =============================================================

# ---- Google OAuth (same value as backend GOOGLE_CLIENT_ID) ----
# DO NOT mark as Sensitive in Vercel!
VITE_GOOGLE_CLIENT_ID="xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com"

# ---- Razorpay (optional, for billing) ----
# DO NOT mark as Sensitive in Vercel!
VITE_RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxxxxxx"

# ---- API URL (LEAVE EMPTY on Vercel - uses relative /api path) ----
# Only set this if backend is on a DIFFERENT domain (e.g. Render)
# VITE_API_URL=
